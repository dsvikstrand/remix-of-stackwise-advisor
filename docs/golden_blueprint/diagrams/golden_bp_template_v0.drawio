                <mxCell id="tradeoffs" value="5) Tradeoffs&#xa;What goes here: upside, constraints, unknowns." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
