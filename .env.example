SEARCH_API_WINDOW_MS=60000
SEARCH_API_MAX=180
YOUTUBE_SEARCH_CACHE_ENABLED=true
YOUTUBE_SEARCH_CACHE_TTL_SECONDS=600
YOUTUBE_CHANNEL_SEARCH_CACHE_TTL_SECONDS=900
YOUTUBE_SEARCH_STALE_MAX_SECONDS=86400
YOUTUBE_SEARCH_DEGRADE_ENABLED=true
YOUTUBE_GLOBAL_LIVE_CALLS_PER_MIN=60
YOUTUBE_GLOBAL_LIVE_CALLS_PER_DAY=20000
YOUTUBE_GLOBAL_COOLDOWN_SECONDS=600
CREDITS_READ_WINDOW_MS=60000
CREDITS_READ_MAX_PER_WINDOW=180
INGESTION_LATEST_MINE_WINDOW_MS=60000
INGESTION_LATEST_MINE_MAX_PER_WINDOW=180
UNLOCK_INTAKE_ENABLED=true
RUN_HTTP_SERVER=true
RUN_INGESTION_WORKER=true
ORACLE_CONTROL_PLANE_ENABLED=false
ORACLE_SUBSCRIPTION_SCHEDULER_MODE=supabase
ORACLE_CONTROL_PLANE_SQLITE_PATH=.runtime/control-plane.sqlite
