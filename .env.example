# Optional toggles
# Emergency-only bypass for credit debits (keeps wallet paths in bypass mode).
# Keep false in normal production operation.
AI_CREDITS_BYPASS=false

# Eval / judge
OPENAI_API_KEY=
# Generation defaults (YouTube + blueprint generation paths)
OPENAI_GENERATION_MODEL=gpt-5.2
OPENAI_GENERATION_FALLBACK_MODEL=o4-mini
OPENAI_GENERATION_REASONING_EFFORT=medium
# Experimental Codex generation path (YouTube generation only)
USE_CODEX_FOR_GENERATION=false
CODEX_EXEC_PATH=codex
CODEX_EXEC_TIMEOUT_MS=90000
CODEX_EXEC_LANE_CONCURRENCY=1
CODEX_EXEC_REASONING_EFFORT=low
CODEX_EXEC_REASONING_EFFORT_FREE=medium
CODEX_EXEC_REASONING_EFFORT_TIER=low
CODEX_FREE_MODEL=gpt-5-mini
CODEX_TIER_MODEL=gpt-5.2
CODEX_FALLBACK_ENABLED=true
CODEX_CIRCUIT_FAILURE_THRESHOLD=5
CODEX_CIRCUIT_COOLDOWN_MS=300000
