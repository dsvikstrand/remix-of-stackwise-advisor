# SOURCE_VIDEO_GENERATE_COOLDOWN_MS=30000
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_DEVELOPER_MODE=true
VITE_CHANNEL_GATES_MODE=bypass
VITE_FEATURE_AUTO_CHANNEL_PIPELINE_V1=true

# Optional toggles
AI_CREDITS_BYPASS=false

# Eval / judge
OPENAI_API_KEY=
# Generation defaults (YouTube + blueprint generation paths)
OPENAI_GENERATION_MODEL=gpt-5.2
OPENAI_GENERATION_FALLBACK_MODEL=o4-mini
OPENAI_GENERATION_REASONING_EFFORT=medium
