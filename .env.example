# Frontend / backend endpoints
VITE_AGENTIC_BACKEND_URL=https://api.bleup.app

# Backend transcript source for YouTube -> Blueprint
# Current default tries YouTube timedtext first, then falls through to the temporary provider, then TranscriptAPI when captions are unavailable upstream.
TRANSCRIPT_PROVIDER=youtube_timedtext
TRANSCRIPTAPI_APIKEY=
VIDEOTRANSCRIBER_TEMP_TIMEOUT_MS=180000
VIDEOTRANSCRIBER_TEMP_FORCE_NEW_SESSION=true
# Optional override to force the temporary provider as the primary path:
# TRANSCRIPT_PROVIDER=videotranscriber_temp
# Shared Webshare proxy transport for opted-in transcript providers (`videotranscriber_temp`)
TRANSCRIPT_USE_WEBSHARE_PROXY=true
WEBSHARE_PROXY_URL=
WEBSHARE_PROXY_HOST=
WEBSHARE_PROXY_PORT=
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
YOUTUBE_DATA_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly
TOKEN_ENCRYPTION_KEY=
YOUTUBE_IMPORT_MAX_CHANNELS=2000
YOUTUBE_OAUTH_STATE_TTL_SECONDS=600
YT2BP_ENABLED=true
YT2BP_OUTPUT_MODE=llm_native
YT2BP_CORE_TIMEOUT_MS=120000
YT2BP_ANON_LIMIT_PER_MIN=6
YT2BP_AUTH_LIMIT_PER_MIN=20
YT2BP_IP_LIMIT_PER_HOUR=30
YT2BP_QUALITY_ENABLED=true
YT2BP_QUALITY_MAX_RETRIES=2
YT2BP_QUALITY_MIN_SCORE=3.5
YT2BP_QUALITY_MODEL=o4-mini
YT2BP_CONTENT_SAFETY_ENABLED=true
YT2BP_SAFETY_BLOCK_ENABLED=false
YT2BP_CONTENT_SAFETY_MAX_RETRIES=1
YT2BP_CONTENT_SAFETY_MODEL=o4-mini
YT2BP_POS_REF_ENABLED=true
YT2BP_POS_REF_MAX_FILES=-1
YT2BP_POS_REF_MAX_CHARS_PER_FILE=-1
YT2BP_POS_REF_MAX_TOTAL_CHARS=-1
YT2BP_TRANSCRIPT_PRUNE_ENABLED=true
YT2BP_TRANSCRIPT_PRUNE_BUDGET_CHARS=4500
YT2BP_TRANSCRIPT_PRUNE_THRESHOLDS=4500,9000,16000
YT2BP_TRANSCRIPT_PRUNE_WINDOWS=1,4,6,8
CHANNEL_GATES_MODE=bypass
AUTO_CHANNEL_PIPELINE_ENABLED=false
AUTO_CHANNEL_DEFAULT_SLUG=general
# AUTO_CHANNEL_CLASSIFIER_MODE: deterministic_v1 | general_placeholder | llm_labeler_v1
AUTO_CHANNEL_CLASSIFIER_MODE=deterministic_v1
AUTO_CHANNEL_FALLBACK_SLUG=general
AUTO_CHANNEL_GATE_MODE=enforce
AUTO_CHANNEL_LEGACY_MANUAL_FLOW_ENABLED=true
ENABLE_DEBUG_ENDPOINTS=false
INGESTION_MAX_PER_SUBSCRIPTION=5
REFRESH_SCAN_COOLDOWN_MS=30000
REFRESH_GENERATE_COOLDOWN_MS=120000
REFRESH_GENERATE_MAX_ITEMS=20
REFRESH_FAILURE_COOLDOWN_HOURS=6
INGESTION_STALE_RUNNING_MS=1800000
SUBSCRIPTION_AUTO_BANNER_MODE=off
SUBSCRIPTION_AUTO_BANNER_CAP=1000
SUBSCRIPTION_AUTO_BANNER_MAX_ATTEMPTS=3
SUBSCRIPTION_AUTO_BANNER_TIMEOUT_MS=12000
SUBSCRIPTION_AUTO_BANNER_BATCH_SIZE=20
SUBSCRIPTION_AUTO_BANNER_CONCURRENCY=1
AUTO_BANNER_STALE_RUNNING_MS=1200000
CREDIT_WALLET_CAPACITY=10
CREDIT_WALLET_INITIAL_BALANCE=10
CREDIT_REFILL_SECONDS_PER_CREDIT=360
GENERATION_DAILY_CAP_ENABLED=true
GENERATION_DAILY_CAP_FREE_LIMIT=5
GENERATION_DAILY_CAP_PLUS_LIMIT=25
GENERATION_DAILY_CAP_RESET_HOUR_UTC=0
GENERATION_DAILY_CAP_BYPASS_USER_IDS=
